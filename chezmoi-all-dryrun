#!/usr/bin/env bash
# chezmoi-all-dryrun — launchd wrapper for `chezmoi-all apply --dry-run --verbose`.
#
# Computes a single timestamped log file and exports it as LOG_FILE so that
# chezmoi-all writes to that file, and redirects this script's own stdout/stderr
# to the same file so launchd-level failures (e.g. missing BEWMAIN) are captured.

set -euo pipefail

: "${BEWMAIN:?BEWMAIN environment variable is not set}"

LOG_DIR="${BEWMAIN}/Data/logs"
mkdir -p "$LOG_DIR"

export LOG_FILE="${LOG_DIR}/chezmoi-all-dryrun-$(date +%Y%m%d-%H%M%S).log"

exec >>"$LOG_FILE" 2>&1

echo "[$(date '+%Y-%m-%d %H:%M:%S')] chezmoi-all-dryrun wrapper starting"
exec /Users/bruce/bin/chezmoi-all apply --dry-run --verbose
